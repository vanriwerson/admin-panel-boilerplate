# Database connection
DB_HOST=HostDaConexaoPostgres
DB_PORT=5432
DB_USER=UsernameDaConexaoPostgres
DB_PASSWORD=SenhaDaConexaoPostgres
DB_NAME=NomeDoBancoDeDados

# Rodar serviço db utilizando Docker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=admin_panel_db

# Roda seed de usuários para desenvolvimento. Setar como false em produção
RUN_USERS_SEED=true

# Application
API_PORT=PortaDaApi

# JWT
JWT_SECRET_KEY=ChaveSecretaJWT

# CORS
WEB_APP_URL=UrlDoFrontend

# Redefinição de senha via e-mail 
RESEND_API_KEY=ChaveDaApiDoResend
RESEND_FROM_EMAIL=EmailRegistradoNoServicoResend